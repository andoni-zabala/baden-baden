---
import { dogs } from '../../content/site.config';

const featured = dogs.filter((d) => d.category === 'show').slice(0, 2);
const placeholder = '/images/placeholder.svg';
---

<section class="featured">
  <div class="featured-header reveal">
    <div class="section-tag">Nuestros Dobermanns</div>
    <h2 class="featured-title">Ejemplares destacados</h2>
  </div>

  <div class="featured-grid">
    {featured.map((dog, i) => (
      <a href="/nuestros-dobermanns" class={`featured-card reveal reveal-delay-${i + 1}`}>
        <div class="featured-photo-wrap">
          <img
            src={dog.photo || placeholder}
            alt={dog.nickname ? `${dog.name} "${dog.nickname}"` : dog.name}
            class="featured-photo"
            width="680"
            height="820"
            loading="lazy"
          />
          <div class="featured-overlay" aria-hidden="true"></div>
        </div>
        <div class="featured-info">
          <h3 class="featured-name">{dog.name}</h3>
          {dog.nickname && <p class="featured-nickname">"{dog.nickname}"</p>}
          {dog.titles && dog.titles.length > 0 && (
            <p class="featured-title-tag">{dog.titles.join(' · ')}</p>
          )}
        </div>
      </a>
    ))}
  </div>

  <div class="featured-footer reveal">
    <a href="/nuestros-dobermanns" class="featured-link">
      Ver todos nuestros Dobermanns →
    </a>
  </div>
</section>

<style>
  .featured {
    padding: 6rem 2.5rem;
    max-width: 1360px;
    margin: 0 auto;
  }

  .featured-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .featured-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 400;
    color: var(--color-text);
    letter-spacing: 0.02em;
    margin-top: 0.5rem;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .featured-card {
    display: block;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    background: var(--color-surface-alt);
  }

  .featured-photo-wrap {
    position: relative;
    aspect-ratio: 5 / 6;
    overflow: hidden;
  }

  .featured-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.6s ease;
    display: block;
  }

  .featured-card:hover .featured-photo {
    transform: scale(1.04);
  }

  .featured-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);
  }

  .featured-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem;
  }

  .featured-name {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    font-weight: 400;
    color: #fff;
    letter-spacing: 0.02em;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .featured-nickname {
    font-family: var(--font-display);
    font-size: 1rem;
    color: rgba(255,255,255,0.65);
    font-style: italic;
    margin-top: 0.25rem;
  }

  .featured-title-tag {
    margin-top: 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
  }

  .featured-footer {
    text-align: center;
    margin-top: 3rem;
  }

  .featured-link {
    color: rgba(245, 240, 232, 0.6);
    text-decoration: none;
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    transition: color 0.2s ease;
    border-bottom: 1px solid rgba(245, 240, 232, 0.2);
    padding-bottom: 2px;
  }

  .featured-link:hover {
    color: #fff;
    border-color: rgba(245, 240, 232, 0.6);
  }

  @media (max-width: 640px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }

    .featured {
      padding: 4rem 1.5rem;
    }
  }
</style>
