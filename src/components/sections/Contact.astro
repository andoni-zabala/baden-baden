---
import { contact, primaryCTA } from '../../content/site.config';
import Button from '../primitives/Button.astro';

function getSocialIcon(platform: string) {
  if (platform === 'instagram') return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`;
  if (platform === 'linkedin') return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`;
  return '';
}
---

<section class="contact" id="contact">
  <div class="contact-inner">
    <div class="contact-info reveal">
      <div class="section-tag">{contact.sectionTag}</div>
      <h2 class="contact-heading" set:html={contact.heading} />
      <p class="contact-sub">{contact.subheading}</p>

      <div class="contact-cta">
        <Button cta={primaryCTA} size="large" />
      </div>

      <div class="contact-details">
        <div class="detail">
          <span class="detail-icon" aria-hidden="true">✉</span>
          <div>
            <span class="detail-label">Email</span>
            <a href={`mailto:${contact.email}`} class="detail-val">{contact.email}</a>
          </div>
        </div>
        <div class="detail">
          <span class="detail-icon" aria-hidden="true">📍</span>
          <div>
            <span class="detail-label">Location</span>
            <span class="detail-val">{contact.location}</span>
          </div>
        </div>
        <div class="detail">
          <span class="detail-icon" aria-hidden="true">🕐</span>
          <div>
            <span class="detail-label">Hours</span>
            <span class="detail-val">{contact.hours}</span>
          </div>
        </div>
      </div>

      <div class="social-links">
        {contact.social.map((s) => (
          <a
            href={s.href}
            class="social-link"
            aria-label={s.label}
            target="_blank"
            rel="noopener noreferrer"
          >
            <Fragment set:html={getSocialIcon(s.platform)} />
            {s.label}
          </a>
        ))}
      </div>
    </div>

    <div class="contact-form-wrap reveal reveal-delay-2">
      <form class="contact-form" name="contact" data-netlify="true">
        <div class="form-row">
          <div class="form-group">
            <label for="name">Full name</label>
            <input
              type="text"
              id="name"
              name="name"
              placeholder={contact.formFields.namePlaceholder}
              required
            />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder={contact.formFields.emailPlaceholder}
              required
            />
          </div>
        </div>

        <div class="form-group">
          <label for="goal">{contact.formFields.goalLabel}</label>
          <select id="goal" name="goal" required>
            <option value="" disabled selected>Select an option…</option>
            {contact.formFields.goalOptions.map((opt) => (
              <option value={opt.value}>{opt.label}</option>
            ))}
          </select>
        </div>

        <div class="form-group">
          <label for="message">{contact.formFields.messageLabel}</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            placeholder={contact.formFields.messagePlaceholder}
            required
          ></textarea>
        </div>

        <Button type="submit" class="form-submit">
          {contact.formFields.submitLabel}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </Button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 8rem 2.5rem;
    max-width: 1360px;
    margin: 0 auto;
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 6rem;
    align-items: start;
  }

  .contact-heading {
    font-size: clamp(2.4rem, 3.5vw, 3.6rem);
    line-height: 1.1;
    color: var(--color-primary);
    margin-bottom: 1.25rem;
  }

  .contact-heading :global(em) {
    font-style: italic;
    color: var(--color-emphasis);
  }

  .contact-sub {
    font-size: 1rem;
    line-height: 1.75;
    color: #666;
    font-weight: 300;
    margin-bottom: 2rem;
  }

  .contact-cta {
    margin-bottom: 2.5rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .detail {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .detail-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .detail-label {
    display: block;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #aaa;
    font-weight: 500;
    margin-bottom: 0.2rem;
  }

  .detail-val {
    font-size: 0.88rem;
    color: var(--color-text);
    font-weight: 400;
    text-decoration: none;
  }

  a.detail-val:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-primary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 100px;
    border: 1.5px solid var(--color-surface-alt);
    transition: all 0.2s ease;
  }

  .social-link:hover {
    background: var(--color-primary);
    color: var(--color-surface);
    border-color: var(--color-primary);
  }

  /* Form */
  .contact-form-wrap {
    background: white;
    border-radius: 24px;
    padding: 2.5rem;
    border: 1.5px solid var(--color-surface-alt);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #777;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1.5px solid var(--color-surface-alt);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
    appearance: none;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #bbb;
  }

  .form-submit {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    justify-content: center;
    font-size: 0.9rem;
  }

  @media (max-width: 1024px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .contact {
      padding: 5rem 1.5rem;
    }

    .contact-form-wrap {
      padding: 1.75rem;
    }
  }
</style>
