---
import { contact, primaryCTA } from '../../content/site.config';
import Button from '../primitives/Button.astro';
---

<section class="litter-hero">
  <div class="litter-hero-inner">
    <div class="litter-content reveal">
      <div class="section-tag">Nuevas Lechigadas</div>
      <h1 class="litter-heading">
        Sumá un <em>Dobermann Baden Baden</em> a tu familia.
      </h1>
      <p class="litter-body">
        Planificamos lechigadas con los mejores ejemplares del criadero. Todos los cachorros son entregados con pedigrí FCA, vacunas al día, desparasitaciones, chip de identificación y asesoramiento post-venta personalizado.
      </p>
      <div class="litter-cta">
        <Button cta={primaryCTA} size="large" />
      </div>
      <p class="litter-note">
        Para consultas sobre disponibilidad de cachorros, completá el formulario más abajo o escribinos directamente por WhatsApp.
      </p>
    </div>

    <div class="litter-visual reveal reveal-delay-2">
      <div class="litter-photo-frame">
        <img
          src="/images/puppies/litter.jpg"
          alt="Cachorros Dobermann Baden Baden"
          class="litter-photo"
          width="520"
          height="420"
          loading="eager"
          onerror="this.src='/images/placeholder.svg'"
        />
      </div>
      <div class="litter-info-card">
        <div class="litter-info-item">
          <span class="litter-info-icon">🐾</span>
          <div>
            <span class="litter-info-label">Pedigrí</span>
            <span class="litter-info-val">FCA certificado</span>
          </div>
        </div>
        <div class="litter-info-item">
          <span class="litter-info-icon">💉</span>
          <div>
            <span class="litter-info-label">Sanidad</span>
            <span class="litter-info-val">Vacunas y desparasitaciones</span>
          </div>
        </div>
        <div class="litter-info-item">
          <span class="litter-info-icon">📋</span>
          <div>
            <span class="litter-info-label">Documentación</span>
            <span class="litter-info-val">Chip + historial completo</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="litter-form" id="consulta">
  <div class="litter-form-inner">
    <div class="litter-form-header reveal">
      <div class="section-tag">Formulario de interés</div>
      <h2 class="litter-form-heading">¿Te interesa un <em>cachorro?</em></h2>
      <p class="litter-form-sub">Completá el formulario y te contactamos a la brevedad con información sobre disponibilidad.</p>
    </div>

    <div class="litter-form-wrap reveal reveal-delay-2">
      <form class="litter-contact-form" name="nuevas-lechigadas" data-netlify="true">
        <div class="form-row">
          <div class="form-group">
            <label for="nombre">Nombre</label>
            <input type="text" id="nombre" name="nombre" placeholder="Juan" required />
          </div>
          <div class="form-group">
            <label for="apellido">Apellido</label>
            <input type="text" id="apellido" name="apellido" placeholder="Pérez" required />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="juan@email.com" required />
        </div>
        <div class="form-group">
          <label for="mensaje">Tu consulta</label>
          <textarea id="mensaje" name="mensaje" rows="5" placeholder="¿Tenés alguna preferencia de sexo, color? ¿Es tu primer Dobermann? Cualquier información que nos ayude a orientarte mejor." required></textarea>
        </div>
        <button type="submit" class="btn-primary form-submit">
          ¡Me interesa!
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .litter-hero {
    padding: 8rem 2.5rem 5rem;
    max-width: 1360px;
    margin: 0 auto;
  }

  .litter-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .litter-heading {
    font-size: clamp(2.4rem, 4vw, 3.8rem);
    line-height: 1.08;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .litter-heading em {
    font-style: italic;
    color: var(--color-emphasis);
  }

  .litter-body {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    font-weight: 300;
    margin-bottom: 2rem;
  }

  .litter-cta {
    margin-bottom: 1.5rem;
  }

  .litter-note {
    font-size: 0.82rem;
    color: #aaa;
    line-height: 1.6;
  }

  .litter-photo-frame {
    border-radius: 24px;
    overflow: hidden;
    background: var(--color-surface-alt);
    margin-bottom: 1.5rem;
  }

  .litter-photo {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
  }

  .litter-info-card {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    border: 1.5px solid var(--color-surface-alt);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .litter-info-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .litter-info-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .litter-info-label {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #aaa;
    font-weight: 500;
    margin-bottom: 0.15rem;
  }

  .litter-info-val {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text);
    font-weight: 400;
  }

  /* Form section */
  .litter-form {
    background: var(--color-surface-alt);
    padding: 6rem 2.5rem;
  }

  .litter-form-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .litter-form-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .litter-form-heading {
    font-size: clamp(2rem, 3vw, 2.8rem);
    color: var(--color-primary);
    line-height: 1.1;
  }

  .litter-form-heading em {
    font-style: italic;
    color: var(--color-emphasis);
  }

  .litter-form-sub {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-top: 0.75rem;
  }

  .litter-form-wrap {
    background: white;
    border-radius: 24px;
    padding: 2.5rem;
    border: 1.5px solid var(--color-surface-alt);
  }

  .litter-contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #777;
  }

  .form-group input,
  .form-group textarea {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1.5px solid var(--color-surface-alt);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #bbb;
  }

  .form-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    font-size: 0.9rem;
  }

  @media (max-width: 1024px) {
    .litter-hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .litter-hero {
      padding-top: 6rem;
    }
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .litter-form-wrap {
      padding: 1.75rem;
    }
  }

  @media (max-width: 480px) {
    .litter-hero,
    .litter-form {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }
</style>
