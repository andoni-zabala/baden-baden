---
import { testimonials, primaryCTA } from '../../content/site.config';
import Button from '../primitives/Button.astro';
---

<section class="testimonials" id="testimonials">
  <div class="testimonials-inner">
    <div class="testimonials-header">
      <div class="section-tag reveal">{testimonials.sectionTag}</div>
      <h2 class="t-heading reveal reveal-delay-1">{testimonials.heading}</h2>
    </div>

    <div class="t-grid">
      {testimonials.items.map((t, i) => (
        <article class={`t-card reveal reveal-delay-${i + 1}`}>
          <div class="t-stars" aria-label="5 stars">★★★★★</div>
          <blockquote class="t-quote">"{t.quote}"</blockquote>
          <div class="t-footer">
            <div class="t-avatar" aria-hidden="true">{t.avatar}</div>
            <div class="t-meta">
              <span class="t-name">{t.name}</span>
              <span class="t-role">{t.role}</span>
            </div>
            <div class="t-result">
              <span class="result-icon" aria-hidden="true">✦</span>
              {t.result}
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="t-cta reveal">
      <p>{testimonials.ctaPrompt}</p>
      <Button cta={primaryCTA} />
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: 8rem 2.5rem;
    background: var(--color-surface-alt);
  }

  .testimonials-inner {
    max-width: 1360px;
    margin: 0 auto;
  }

  .testimonials-header {
    margin-bottom: 3.5rem;
  }

  .t-heading {
    font-size: clamp(2.4rem, 3.5vw, 3.6rem);
    color: var(--color-primary);
    line-height: 1.1;
  }

  .t-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .t-card {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    border: 1.5px solid transparent;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .t-card:hover {
    border-color: var(--color-surface-alt);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.07);
  }

  .t-stars {
    color: var(--color-decorative);
    font-size: 0.9rem;
    letter-spacing: 0.1em;
  }

  .t-quote {
    font-family: var(--font-display);
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--color-text);
    font-style: normal;
    font-weight: 400;
    flex: 1;
    border: none;
    padding: 0;
  }

  .t-footer {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-surface-alt);
    flex-wrap: wrap;
  }

  .t-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .t-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
  }

  .t-name {
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .t-role {
    font-size: 0.72rem;
    color: #999;
    font-weight: 300;
  }

  .t-result {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-primary);
    padding: 0.35rem 0.8rem;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .result-icon {
    color: var(--color-decorative);
    font-size: 0.6rem;
  }

  .t-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 3rem;
    background: white;
    border-radius: 20px;
    border: 1.5px solid var(--color-surface-alt);
  }

  .t-cta p {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-primary);
    font-weight: 400;
    font-style: italic;
  }

  @media (max-width: 1024px) {
    .t-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
    }
  }

  @media (max-width: 480px) {
    .testimonials {
      padding: 5rem 1.5rem;
    }
  }
</style>
