---
import { process, primaryCTA } from '../../content/site.config';
import Button from '../primitives/Button.astro';
---

<section class="how" id="how-it-works">
  <div class="how-inner">

    <div class="how-header">
      <div class="section-tag reveal">{process.sectionTag}</div>
      <h2 class="how-heading reveal reveal-delay-1">{process.heading}</h2>
      <p class="how-sub reveal reveal-delay-2">{process.subheading}</p>
    </div>

    <div class="how-steps">
      {process.steps.map((step, i) => (
        <>
          <div class={`step reveal reveal-delay-${i + 1}`}>
            <div class="step-number" aria-hidden="true">{step.number}</div>
            <div class="step-content">
              <h3 class="step-title">{step.title}</h3>
              <p class="step-body">{step.body}</p>
            </div>
          </div>
          {i < process.steps.length - 1 && (
            <div class="step-connector" aria-hidden="true"></div>
          )}
        </>
      ))}
    </div>

    <div class="how-cta reveal">
      <Button cta={primaryCTA} />
    </div>

  </div>
</section>

<style>
  .how {
    padding: 8rem 2.5rem;
    background: var(--color-surface-alt);
  }

  .how-inner {
    max-width: 1360px;
    margin: 0 auto;
  }

  .how-header {
    max-width: 560px;
    margin-bottom: 4.5rem;
  }

  .how-heading {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 3.5vw, 3.6rem);
    line-height: 1.1;
    color: var(--color-primary);
    font-weight: 400;
    letter-spacing: -0.015em;
    margin-bottom: 1rem;
  }

  .how-sub {
    font-size: 1rem;
    line-height: 1.75;
    color: #666;
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  /* Desktop: 4 steps with 3 connectors between them */
  .how-steps {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    align-items: start;
    margin-bottom: 4rem;
  }

  .step {
    padding: 0 1rem;
  }

  .step-number {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 500;
    color: var(--color-accent-light);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .step-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-primary);
    font-weight: 500;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  .step-body {
    font-size: 0.9rem;
    line-height: 1.75;
    color: #666;
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  .step-connector {
    width: 48px;
    height: 1px;
    background: color-mix(in srgb, var(--color-primary) 20%, transparent);
    margin-top: 1.75rem;
    position: relative;
    flex-shrink: 0;
  }

  .step-connector::after {
    content: '';
    position: absolute;
    right: -1px;
    top: -3px;
    width: 6px;
    height: 6px;
    border-top: 1.5px solid color-mix(in srgb, var(--color-primary) 30%, transparent);
    border-right: 1.5px solid color-mix(in srgb, var(--color-primary) 30%, transparent);
    transform: rotate(45deg);
  }

  .how-cta {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 1024px) {
    .how-steps {
      grid-template-columns: 1fr;
    }

    .step {
      padding: 0;
    }

    .step-connector {
      width: 1px;
      height: 32px;
      margin-top: 0;
      margin-left: 0;
    }

    .step-connector::after {
      right: -3px;
      top: auto;
      bottom: -1px;
      transform: rotate(135deg);
    }
  }

  @media (max-width: 480px) {
    .how {
      padding: 5rem 1.5rem;
    }
  }
</style>
