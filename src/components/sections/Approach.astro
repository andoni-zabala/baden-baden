---
import { approach, primaryCTA } from '../../content/site.config';
import Button from '../primitives/Button.astro';
import SectionTag from '../primitives/SectionTag.astro';
---

<section class="approach" id="approach">
  <div class="approach-inner">
    <div class="approach-quote-col reveal">
      <SectionTag variant="light">{approach.sectionTag}</SectionTag>

      <blockquote class="big-quote reveal reveal-delay-1" set:html={approach.quote} />

      <p class="approach-body reveal reveal-delay-2">{approach.body}</p>

      <div class="reveal reveal-delay-3">
        <Button cta={primaryCTA} variant="light" />
      </div>
    </div>

    <div class="principles-col">
      {approach.principles.map((p, i) => (
        <div class={`principle reveal reveal-delay-${i + 1}`}>
          <div class="principle-num" aria-hidden="true">0{i + 1}</div>
          <div class="principle-content">
            <h3 class="principle-title">{p.title}</h3>
            <p class="principle-body">{p.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .approach {
    background: var(--color-primary);
    padding: 8rem 2.5rem;
    position: relative;
    overflow: hidden;
  }

  .approach::before,
  .approach::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .approach::before {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(122, 158, 104, 0.15) 0%, transparent 70%);
    top: -200px;
    right: -150px;
  }

  .approach::after {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(200, 96, 58, 0.1) 0%, transparent 70%);
    bottom: -100px;
    left: 10%;
  }

  .approach-inner {
    max-width: 1360px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    position: relative;
    z-index: 1;
  }

  .big-quote {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 2.8vw, 2.8rem);
    line-height: 1.35;
    color: var(--color-surface);
    font-weight: 400;
    font-style: normal;
    margin-bottom: 2rem;
    border: none;
    padding: 0;
  }

  .big-quote :global(em) {
    font-style: italic;
    color: var(--color-accent-light);
  }

  .approach-body {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(250, 247, 240, 0.65);
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .principles-col {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .principle {
    display: flex;
    gap: 1.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid rgba(250, 247, 240, 0.1);
  }

  .principle:last-child {
    border-bottom: none;
  }

  .principle-num {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: rgba(250, 247, 240, 0.2);
    font-weight: 500;
    flex-shrink: 0;
    padding-top: 0.1rem;
    width: 2rem;
  }

  .principle-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-surface);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .principle-body {
    font-size: 0.9rem;
    line-height: 1.75;
    color: rgba(250, 247, 240, 0.6);
    font-weight: 300;
  }

  @media (max-width: 1024px) {
    .approach-inner {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }
  }

  @media (max-width: 480px) {
    .approach {
      padding: 5rem 1.5rem;
    }
  }
</style>
