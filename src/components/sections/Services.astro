---
import { services, primaryCTA } from '../../content/site.config';
import Button from '../primitives/Button.astro';
---

<section class="services" id="services">
  <div class="services-inner">
    <div class="services-header">
      <div class="section-tag reveal">{services.sectionTag}</div>
      <h2 class="services-heading reveal reveal-delay-1" set:html={services.heading} />
      <p class="services-sub reveal reveal-delay-2">{services.subheading}</p>
      <div class="services-areas reveal reveal-delay-3">
        {services.areaLabels.map((label) => (
          <span class="area-tag">{label}</span>
        ))}
      </div>
    </div>

    <div class="services-grid">
      {services.items.map((s, i) => (
        <div class={`service-card ${s.featured ? 'service-card--featured' : ''} reveal reveal-delay-${i + 2}`}>
          <div class="card-top">
            <div class="card-number">{s.number}</div>
            <div class="card-icon" aria-hidden="true">{s.icon}</div>
          </div>
          <h3 class="card-title">{s.title}</h3>
          <p class="card-tagline">{s.tagline}</p>
          <p class="card-desc">{s.description}</p>
          <ul class="card-features">
            {s.features.map((f) => (
              <li>
                <span class="feat-check" aria-hidden="true">✓</span>
                {f}
              </li>
            ))}
          </ul>
          <div class="card-footer">
            <span class="card-price">{s.price}</span>
            <Button cta={primaryCTA} variant={s.featured ? 'light' : 'outline'} />
          </div>
        </div>
      ))}
    </div>

    <p class="services-modality reveal">{services.modalityNote}</p>
  </div>
</section>

<style>
  .services {
    padding: 8rem 2.5rem;
    background: var(--color-surface);
  }

  .services-inner {
    max-width: 1360px;
    margin: 0 auto;
  }

  .services-header {
    max-width: 560px;
    margin-bottom: 4rem;
  }

  .services-heading {
    font-size: clamp(2.4rem, 3.5vw, 3.6rem);
    line-height: 1.1;
    color: var(--color-primary);
    margin-bottom: 1.25rem;
  }

  .services-heading :global(em) {
    font-style: italic;
    color: var(--color-emphasis);
  }

  .services-sub {
    font-size: 1rem;
    line-height: 1.75;
    color: #666;
    font-weight: 300;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .service-card {
    background: white;
    border-radius: 20px;
    padding: 2.25rem;
    border: 1.5px solid var(--color-surface-alt);
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
  }

  .service-card--featured {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-surface);
  }

  .service-card--featured .card-number,
  .service-card--featured .card-title,
  .service-card--featured .card-tagline,
  .service-card--featured .card-desc {
    color: var(--color-surface);
  }

  .service-card--featured .card-price {
    color: var(--color-accent-light);
  }

  .service-card--featured .feat-check {
    color: var(--color-accent-light);
  }

  .service-card--featured .card-features li {
    color: rgba(250, 247, 240, 0.8);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .card-number {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .service-card--featured .card-number {
    color: var(--color-accent-light);
  }

  .card-icon {
    font-size: 1.5rem;
    color: var(--color-decorative);
    opacity: 0.7;
  }

  .card-title {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
    line-height: 1.2;
  }

  .card-tagline {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .card-desc {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #666;
    margin-bottom: 1.5rem;
    font-weight: 300;
  }

  .card-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
    flex: 1;
  }

  .card-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: #555;
    font-weight: 400;
  }

  .feat-check {
    color: var(--color-accent);
    font-size: 0.75rem;
    flex-shrink: 0;
    font-weight: 600;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }

  .service-card--featured .card-footer {
    border-top-color: rgba(255, 255, 255, 0.12);
  }

  .card-price {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-primary);
  }

  .services-areas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.5rem;
  }

  .area-tag {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 12%, transparent);
    padding: 0.3rem 0.85rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .services-modality {
    margin-top: 2rem;
    font-size: 0.85rem;
    color: #888;
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
    }
  }

  @media (max-width: 480px) {
    .services {
      padding: 5rem 1.5rem;
    }
  }
</style>
