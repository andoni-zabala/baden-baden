---
import type { CTAConfig } from '../../types';

interface Props {
  cta?: CTAConfig;
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost' | 'light';
  size?: 'default' | 'large' | 'small';
  type?: 'button' | 'submit';
  class?: string;
  target?: string;
  rel?: string;
}

const {
  cta,
  href: explicitHref,
  variant = 'primary',
  size = 'default',
  type = 'button',
  class: className = '',
  target: explicitTarget,
  rel: explicitRel,
} = Astro.props;

function resolveCTA(cta: CTAConfig): { href: string; target: string; rel: string } {
  switch (cta.type) {
    case 'whatsapp': {
      const number = cta.value.replace(/\D/g, '');
      const text = cta.message ? encodeURIComponent(cta.message) : '';
      return {
        href: `https://wa.me/${number}${text ? `?text=${text}` : ''}`,
        target: '_blank',
        rel: 'noopener noreferrer',
      };
    }
    case 'calendly':
      return { href: cta.value, target: '_blank', rel: 'noopener noreferrer' };
    case 'phone':
      return { href: `tel:${cta.value}`, target: '_self', rel: '' };
    case 'email':
      return { href: `mailto:${cta.value}`, target: '_self', rel: '' };
    case 'url':
    default:
      return {
        href: cta.value,
        target: cta.value.startsWith('http') ? '_blank' : '_self',
        rel: cta.value.startsWith('http') ? 'noopener noreferrer' : '',
      };
  }
}

const resolved = cta ? resolveCTA(cta) : null;
const href = resolved?.href ?? explicitHref ?? '#';
const target = explicitTarget ?? resolved?.target ?? '_self';
const rel = explicitRel ?? resolved?.rel ?? '';
const label = cta?.label;
const isWhatsApp = cta?.type === 'whatsapp';
const isCalendly = cta?.type === 'calendly';
const isLink = !!href && href !== '#';
---

{isLink ? (
  <a
    href={href}
    target={target}
    rel={rel || undefined}
    class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
  >
    {isWhatsApp && (
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
    )}
    {isCalendly && (
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
    )}
    <slot>{label}</slot>
  </a>
) : (
  <button
    type={type}
    class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
  >
    <slot>{label}</slot>
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 500;
    letter-spacing: 0.06em;
    transition: all 0.25s ease;
    cursor: pointer;
    font-family: var(--font-sans);
    border: none;
    line-height: 1;
  }

  /* Sizes */
  .btn--default { font-size: 0.82rem; padding: 0.875rem 2rem; }
  .btn--large   { font-size: 0.9rem;  padding: 1rem 2.5rem;   }
  .btn--small   { font-size: 0.75rem; padding: 0.625rem 1.5rem; }

  /* Variants */
  .btn--primary {
    background: var(--color-primary);
    color: var(--color-surface);
  }
  .btn--primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.2);
  }

  .btn--outline {
    background: transparent;
    color: var(--color-primary);
    border: 1.5px solid var(--color-primary);
  }
  .btn--outline:hover {
    background: var(--color-primary);
    color: var(--color-surface);
    transform: translateY(-2px);
  }

  /* Light variant — for use on dark backgrounds */
  .btn--light {
    background: var(--color-surface);
    color: var(--color-primary);
    border: none;
  }
  .btn--light:hover {
    background: var(--color-surface-alt);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.15);
  }

  .btn--ghost {
    background: transparent;
    color: var(--color-surface);
    border: 1.5px solid rgba(255, 255, 255, 0.4);
  }
  .btn--ghost:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.7);
    transform: translateY(-2px);
  }
</style>
