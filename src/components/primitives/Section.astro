---
interface Props {
  id?: string;
  class?: string;
  variant?: 'default' | 'alt' | 'dark' | 'none';
  width?: 'wide' | 'narrow';
  padding?: 'default' | 'large' | 'none';
  as?: 'section' | 'div';
}

const {
  id,
  class: className = '',
  variant = 'default',
  width = 'wide',
  padding = 'default',
  as: Tag = 'section',
} = Astro.props;
---

<Tag
  id={id}
  class:list={['section-wrapper', `variant-${variant}`, `width-${width}`, `padding-${padding}`, className]}
>
  <div class="section-inner">
    <slot />
  </div>
</Tag>

<style>
  .section-wrapper {
    width: 100%;
  }

  .variant-default { background: var(--color-surface); }
  .variant-alt     { background: var(--color-surface-alt); }
  .variant-dark    { background: var(--color-primary); color: var(--color-surface); }
  .variant-none    { background: transparent; }

  .section-inner {
    margin: 0 auto;
  }

  .width-wide  .section-inner { max-width: 1360px; }
  .width-narrow .section-inner { max-width: 860px; }

  .padding-default .section-inner { padding: 8rem 2.5rem; }
  .padding-large   .section-inner { padding: 10rem 2.5rem; }
  .padding-none    .section-inner { padding: 0 2.5rem; }

  @media (max-width: 1024px) {
    .padding-default .section-inner { padding: 5rem 2.5rem; }
    .padding-large   .section-inner { padding: 6rem 2.5rem; }
  }

  @media (max-width: 480px) {
    .padding-default .section-inner,
    .padding-large   .section-inner { padding: 4rem 1.5rem; }
  }
</style>
